{
    "name": "distributed-backup-manager-core",
    "description": "Core library for the distributed backup manager",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "postinstall": "npx patch-package",
        "lint": "eslint 'src/**/*.{js,cjs,mjs,jsx,ts,cts,mts,tsx}'",
        "typecheck": "tsc --noEmit",
        "test": "jest",
        "build": "tsc",
        "typeorm:migration:create": "yarn typeorm migration:create",
        "start": "node --env-file='.env' ./dist/index.js",
        "sync-server:start:dev": "tsx --env-file='.env' ./src/modules/sync-server/server.ts",
        "sync-server:start:prod": "node --env-file='.env' ./dist/modules/sync-server/server.js"
    },
    "dependencies": {
        "@nestjs/common": "^11.1.11",
        "@nestjs/core": "^11.1.11",
        "@nestjs/platform-express": "^11.1.11",
        "@nestjs/swagger": "^11.2.3",
        "arg": "^5.0.2",
        "axios": "^1.13.2",
        "bcryptjs": "^3.0.3",
        "class-validator": "^0.14.3",
        "dedent": "^1.7.1",
        "express": "^5.2.1",
        "form-data": "^4.0.5",
        "jose": "^6.1.3",
        "multer": "^2.0.2",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "sqlite3": "^5.1.7",
        "typeorm": "^0.3.28",
        "uuid": "^13.0.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@stylistic/eslint-plugin": "^5.6.1",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/multer": "^2.0.0",
        "@vinicius1313/eslint-config": "^2.2.0",
        "@vinicius1313/tsconfig": "^2.0.0",
        "eslint": "^9.39.2",
        "jest": "^30.2.0",
        "ts-jest": "^29.4.6",
        "tsx": "^4.21.0",
        "type-fest": "^5.3.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.51.0"
    },
    "engines": {
        "node": ">=18"
    }
}
